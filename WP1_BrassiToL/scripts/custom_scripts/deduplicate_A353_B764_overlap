#!/usr/bin/env python3
"""
deduplicate_A353_B764_overlap.py

Post-1c deduplication of loci that occur in BOTH the A353 and B764 bait sets.

What this script does
---------------------
1. Reads the cleaned sequence-list output folder created by 1c:
     <seq_root>/
       loci_consensus/
       loci_contigs/
       samples_consensus/
       samples_contigs/

2. For each predefined overlapping A353/B764 gene pair:
     - inspects the cleaned locus FASTAs
     - summarizes recovery statistics for both versions:
         * number of sequences recovered
         * mean sequence length
         * total recovered bp
       separately for consensus and contigs

3. Chooses which version to keep and which to remove.
   Updated decision rule:
     a) compare n_consensus
        - if absolute difference >= --min_diff_n_consensus, keep higher n_consensus
     b) otherwise compare mean_len_consensus
     c) if tie: compare total_bp_consensus
     d) if tie: compare n_contig
        - if absolute difference >= --min_diff_n_contig, keep higher n_contig
     e) if tie: compare mean_len_contig
     f) if tie: compare total_bp_contig
     g) if still tie: use --prefer_on_tie

4. Removes the losing locus from:
     - loci_consensus/    (whole FASTA file; moved to backup)
     - loci_contigs/      (whole FASTA file; moved to backup)
     - samples_consensus/ (remove relevant records from all sample FASTAs)
     - samples_contigs/   (remove relevant records from all sample FASTAs)

5. Writes output summary files in <seq_root>/:
     - bait_overlap_deduplication_stats.csv
     - bait_overlap_deduplication_summary.txt

Notes
-----
- Intended for target_id_mode = dash, where:
    B764 loci look like 1G08490, 2G31955, ...
    A353 loci look like 5018, 4932, ...
- Safe mode:
    * locus FASTAs are MOVED to a backup folder
    * affected sample FASTAs are backed up before rewriting
"""

import argparse
import csv
import shutil
import sys
from pathlib import Path
from typing import Dict, List, Tuple, Set

from Bio import SeqIO
from Bio.SeqRecord import SeqRecord
from Bio.SeqIO.FastaIO import FastaWriter


